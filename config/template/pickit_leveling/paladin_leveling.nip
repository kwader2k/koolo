[type] == armor && [flag] == runeword # [ias] == 45 && [fhr] == 20 # [merctier] == 20000                                                                                                                                                                                                                                                                                                                                                         // Treachery (45 ias/20 fhr/5% ctc lvl 15 fade/25% ctc lvl 15 venom/+2 sin skills/30 cr/50 pr/50 gf; req [lvl: 43+ | str: base | dex: base])
