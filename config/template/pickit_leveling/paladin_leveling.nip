// IGNORED by default, this directory is ONLY evaluated DURING the character leveling process.
// Rules here are included ADDITIONALLY to the main pickit rules

// ## Runes ##
[name] == elrune # # [maxquantity] == 1    // El Rune
[name] == eldrune # # [maxquantity] == 0   // Eld Rune
[name] == tirrune # # [maxquantity] == 2   // Tir Rune
[name] == nefrune # # [maxquantity] == 1   // Nef Rune
[name] == ethrune # # [maxquantity] == 1   // Eth Rune
[name] == ithrune # # [maxquantity] == 0   // Ith Rune
[name] == talrune # # [maxquantity] == 3   // Tal Rune
[name] == ralrune # # [maxquantity] == 4   // Ral Rune
[name] == ortrune # # [maxquantity] == 3   // Ort Rune
[name] == thulrune # # [maxquantity] == 3  // Thul Rune
[name] == amnrune # # [maxquantity] == 3   // Amn Rune
[name] == solrune # # [maxquantity] == 2   // Sol Rune
[name] == shaelrune # # [maxquantity] == 2 // Shael Rune
[name] == dolrune # # [maxquantity] == 0   // Dol Rune
[name] == helrune # # [maxquantity] == 3   // Hel Rune
[name] == iorune # # [maxquantity] == 1    // Io Rune
[name] == lumrune # # [maxquantity] == 1   // Lum Rune
[name] == korune # # [maxquantity] == 0    // Ko Rune
[name] == falrune # # [maxquantity] == 0   // Fal Rune
[name] == lemrune # # [maxquantity] == 1   // Lem Rune
[name] == pulrune                          // Pul Rune
[name] == umrune                           // Um Rune
[name] == malrune                          // Mal Rune
[name] == istrune                          // Ist Rune
[name] == gulrune                          // Gul Rune
[name] == vexrune                          // Vex Rune
[name] == ohmrune                          // Ohm Rune
[name] == lorune                           // Lo Rune
[name] == surrune                          // Sur Rune
[name] == berrune                          // Ber Rune
[name] == jahrune                          // Jah Rune
[name] == chamrune                         // Cham Rune
[name] == zodrune                          // Zod Rune

