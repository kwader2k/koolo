// ## Merc Weapon ##
([name] == scythe || [name] == warscythe) && [quality] >= normal && [quality] <= superior # [sockets] == 2 # [maxquantity] == 1                                                                                                         // Strength base (2os scythe/war scythe)
[type] == polearm && [flag] == runeword # [itemcrushingblow] == 25 && [strength] == 20 && [lifeleech] == 7 # [merctier] == 10000                                                                                                        // Strength (25 cb/7% ll/20 str/10 vit/2 mana per kill/35 ed; req [lvl: 25+ | str: base | dex: base])
([name] == scythe || [name] == warscythe || [name] == battlescythe || [name] == grimscythe || [name] == thresher || [name] == giantthresher) && [quality] >= normal && [quality] <= superior # [sockets] == 4 # [maxquantity] == 1      // Insight base (4os scythe/war/battle/grim scythe/thresher/giant thresher)
([name] == battlescythe || [name] == grimscythe || [name] == thresher || [name] == giantthresher) && [quality] >= normal && [quality] <= superior && [flag] == ethereal && [class] >= exceptional # [sockets] == 4 # [maxquantity] == 1 // Insight base (4os Eth battle/grim scythe/thresher/giant thresher)
([name] == thresher || [name] == giantthresher) && [quality] >= normal && [quality] <= superior && [flag] == ethereal && [class] == elite # [sockets] == 4 # [maxquantity] == 1                                                         // Insight base (4os Eth thresher/giant thresher)
[type] == polearm && [flag] == runeword # [meditationaura] >= 12 # [merctier] == 20000                                                                                                                                                  // Insight (meditation aura 12-17/200-260 ed/180-250 ar/+9 min/5-30 fire dmg/75 poison dmg/5 sec/1-6 critical strike/23 mf/2 mana per kill; req [lvl: 27+ | str: base | dex: base])

// ## Merc Helm ##
[type] == helm && [quality] >= normal && [quality] <= superior && [class] != elite # [sockets] == 3 # [maxquantity] == 1                                  // Cure base (3os normal/exceptional helm)
([name] == demonhead || [name] == bonevisage) && [quality] >= normal && [quality] <= superior && [flag] == ethereal # [sockets] == 3 # [maxquantity] == 1 // Cure base (3os Eth elite helm)
[type] == helm && [flag] == runeword # [poisonresist] >= 40 # [merctier] == 20000                                                                         // Cure (cleansing aura/40-60 pr/75-100 ed; req [lvl: 35+ | str: base | dex: base])

// ## Merc Armor ##
